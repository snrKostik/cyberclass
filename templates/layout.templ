package templates

templ Layout(
    title string,
) {

<!DOCTYPE html>

<html lang="en">

<head>
    <meta charset="UTF-8">

    <meta
        name="viewport"
        content="width=device-width, initial-scale=1.0"
    >

    <title>{ title }</title>

    <script src="https://unpkg.com/htmx.org@1.9.12"></script>

    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-zinc-950 text-zinc-100 min-h-screen">

    { children... }

</body>

</html>
}
